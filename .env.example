# =============================================================================
# Cool Meals Leads — copy to .env.local (web) and apps/api/.env (api)
# =============================================================================

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (API + Next server). Never expose to the browser.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API
API_PORT=3001
# Public URL of the API (used by the web app)
NEXT_PUBLIC_API_URL=http://localhost:3001

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000

# Optional: shared secret for internal API calls until Auth is wired
# INTERNAL_API_SECRET=change-me-in-production
