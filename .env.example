# =============================================================================
# Cool Meals Leads — copy to `.env` in the repo root:
#   cp .env.example .env
#
# One real file for local: `.env` (gitignored).
# Vercel: set the same keys in each project (web / api) dashboard.
# =============================================================================

# --- Mode (web) ---
# true  = UI con mocks (sin API)
# false = UI → API → Supabase
NEXT_PUBLIC_DEMO_MODE=false

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# --- Local API + CORS ---
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,https://tool-coolmeals-web.vercel.app

# Optional until Auth
# INTERNAL_API_SECRET=change-me-in-production

# --- Kapso (WhatsApp) — API only ---
KAPSO_API_BASE_URL=https://api.kapso.ai
KAPSO_API_KEY=your-kapso-project-api-key
KAPSO_PHONE_NUMBER_ID=your-kapso-phone-number-id
# KAPSO_WORKFLOW_ID=454904ce-8fba-423f-bf08-32135f694b14
# Horas en handoff tras derivado / atención humana / quiere ser dist. / sin cobertura / muestras → Finalizado (default 24)
# DERIVE_HANDOFF_HOURS=24
# Mid-flujo sin respuesta → Esperando respuesta + mensaje + handoff (default 22)
# ABANDONED_TO_WAITING_HOURS=22
# Luego en Esperando respuesta → Finalizado (default 22)
# ESPERANDO_TO_FINALIZE_HOURS=22
# ABANDONED_NUDGE_MESSAGE=Hola! ¿Tenés alguna consulta más? Si no recibimos respuesta, vamos a cerrar esta conversación. Quedamos atentos.
# CRON_SECRET=change-me-for-cron-endpoint


# --- Google Sheets — API only ---
# Red comercial = tabla Distribuidores en la UI (NO sheet).
# GOOGLE_SHEET_DERIVED_DISTRIBUTORS_ID=
# GOOGLE_SHEET_SAMPLE_LOGISTICS_ID=
# GOOGLE_SHEET_COMMERCIAL_ATTENTION_ID=   # dist / rep / fasón (columna tipo_cliente)
# GOOGLE_SHEET_NO_COVERAGE_ID=            # sin cobertura (recontacto)
# GOOGLE_SHEETS_RANGE=Sheet1

# Preferido (Apps Script webhook) — ver apps/api/scripts/google-sheets-append.gs
# GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
# GOOGLE_SHEETS_WEBHOOK_SECRET=una-frase-secreta-larga

# Alternativa service account (si la org permite keys):
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# GOOGLE_SERVICE_ACCOUNT_JSON=
